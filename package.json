{
  "name": "croptrack-client-server",
  "version": "1.0.0",
  "description": "Sistema de gestión agrícola - CropTrack",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "test": "cd server && npm test && cd ../client && npm test"
  },
  "keywords": ["agriculture", "crop-management", "fullstack"],
  "author": "Andres",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}