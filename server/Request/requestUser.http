### ============================================================
### USERS - SUPERVISORES Y TRABAJADORES
### Ejecutar después de requestRegister.http
### Los IDs generados se usan en requestCrops.http,
### requestMeasurements.http y requestTasks.http
### ============================================================

@baseUrl = https://croptrack-client-server.onrender.com
@empresa = Agro San Martín S.A.

### ============================================================
### BLOQUE A - CREAR SUPERVISORES (3)
### ============================================================

###
# Supervisor 1 - Roberto Sánchez (zona Maíz - Lote Norte)
# Respuesta: { "userId": "...", "usuario": "sup_roberto" }
# @name crearSup1
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "usuario": "sup_roberto",
  "contrasena": "Super2025!",
  "nombre": "Roberto",
  "apellido": "Sánchez",
  "email": "roberto.sanchez@agrosanmartin.com",
  "empresa": "{{empresa}}",
  "telefono": "2615401234",
  "rol": "supervisor"
}

