# B2 - Control de pulgón del maíz (COMPLETADA - urgente)
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "empresa": "{{empresa}}",
  "cultivo_id": "{{crop1Id}}",
  "creado_por": "{{adminId}}",
  "asignado_a": "{{trab1Id}}",
  "titulo": "Control de pulgón del maíz (Rhopalosiphum maidis)",
  "descripcion": "Tratamiento insecticida ante detección de colonias de pulgón en hojas del tercio superior en estadio V10. Umbral superado: > 200 pulgones/planta en 30% de plantas muestreadas.",
  "prioridad": "urgente",
  "estado": "completada",
  "fecha_inicio": "2025-12-05",
  "fecha_limite": "2025-12-08",
  "observaciones": "Imidacloprid 0.35 L/ha + aceite mineral 0.5%. Aplicación con pulverizadora de 28 m de barra. Control evaluado a los 7 días: 95% reducción de colonias. Sin reinfestación en 21 días."
}

