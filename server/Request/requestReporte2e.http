### ============================================================
### PASO 4 — CREAR COSECHA DE LIMONEROS (2 AÑOS)
### Respuesta: { "id": "..." }
### ============================================================

###
# @name crearCosecha
POST {{baseUrl}}/api/crops
Content-Type: application/json

{
  "usuario_creador_id": "{{crearAdmin.response.body.userId}}",
  "empresa": "{{empresa}}",
  "nombre": "Limoneros Eureka 2024-2026",
  "tipo": "Frutal",
  "variedad": "Eureka Premium",
  "area_hectareas": 12.5,
  "ubicacion": "Lote Central — Finca Los Limoneros",
  "fecha_siembra": "2024-01-15",
  "fecha_cosecha_estimada": "2026-01-15",
  "estado": "en_crecimiento",
  "notas": "Plantación de limoneros Eureka en conducción eje central. Marco 5x4m, 500 plantas/ha. Riego por goteo instalado. Objetivo: 35 ton/ha en plena producción. Zona: Mendoza Norte, 830 msnm."
}


### ============================================================
### PASO 5 — ASIGNAR TRABAJADORES A LA COSECHA
### ============================================================

###
PUT {{baseUrl}}/api/crops/{{crearCosecha.response.body.id}}/workers
Content-Type: application/json

{
  "workerIds": [
    "{{crearSup.response.body.userId}}",
    "{{crearTrab1.response.body.userId}}",
    "{{crearTrab2.response.body.userId}}",
    "{{crearTrab3.response.body.userId}}"
  ]
}


### ============================================================
### PASO 6 — LOGIN ADMIN (verificar acceso)
### ============================================================

###
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "usuario": "{{adminUser}}",
  "contrasena": "{{adminPass}}",
  "rol": "administrador"
}


### ============================================================
### PASO 7 — MEDICIONES (32 mediciones — 2 años)
###
### Tipos: temperatura · humedad · ph · nutrientes · altura ·
###        peso · rendimiento · plaga · enfermedad ·
###        riego · fertilizacion
### ============================================================

### ── 2024 ENE ─────────────────────────────────────────────────

###
# M01 — Temperatura inicial post-transplante
POST {{baseUrl}}/api/measurements
Content-Type: application/json

{
  "cultivo_id": "{{crearCosecha.response.body.id}}",
  "usuario_id": "{{crearSup.response.body.userId}}",
  "tipo_medicion": "temperatura",
  "valor": 27.2,
  "unidad": "celsius",
  "fecha_medicion": "2024-01-20T08:00:00",
  "observaciones": "Temperatura diurna favorable para el arraigo de los plantines. Sin estrés térmico visible en las primeras hojas."
}

