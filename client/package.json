{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "eject": "react-scripts eject",
    "test": "jest --silent",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --verbose",
    "test:verbose": "jest --verbose",
    "test:unit": "jest --testPathPattern=tests/unit --verbose",
    "test:unit:coverage": "jest --testPathPattern=tests/unit --coverage --verbose",
    "test:unit:components": "jest --testPathPattern=tests/unit/components",
    "test:unit:services": "jest --testPathPattern=tests/unit/services",
    "test:unit:utils": "jest --testPathPattern=tests/unit/utils",
    "test:integration": "jest --testPathPattern=tests/integration --verbose",
    "test:integration:coverage": "jest --testPathPattern=tests/integration --coverage --verbose",
    "test:all": "jest --coverage --verbose",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --silent",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "cypress:open": "cypress open --config-file tests/cypress.config.js",
    "cypress:run": "cypress run --config-file tests/cypress.config.js",
    "cypress:run:headed": "cypress run --config-file tests/cypress.config.js --headed",
    "test:e2e": "cypress run --config-file tests/cypress.config.js",
    "test:e2e:headed": "cypress run --config-file tests/cypress.config.js --headed",
    "test:e2e:chrome": "cypress run --config-file tests/cypress.config.js --browser chrome",
    "test:e2e:firefox": "cypress run --config-file tests/cypress.config.js --browser firefox"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^29.7.0",
    "cypress": "^15.9.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}